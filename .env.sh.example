# Environment Variables for Terraform

# Optional: Set these before running terraform commands

export TF_VAR_aws_region="ap-south-1"
export TF_VAR_app_name="kerala-toors"
export TF_VAR_environment="production"
export TF_VAR_container_port="80"
export TF_VAR_container_cpu="256"
export TF_VAR_container_memory="512"
export TF_VAR_desired_count="2"
export TF_VAR_docker_image_url="omwarkri123/react-app:latest"
export TF_VAR_domain_name="kerala-toors.com"

# AWS Configuration
export AWS_REGION="ap-south-1"
export AWS_PROFILE="default"

# Terraform Logging (optional)
# export TF_LOG="DEBUG"
# export TF_LOG_PATH="./terraform.log"

# Usage:
# source .env.sh
# terraform apply
