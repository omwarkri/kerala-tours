cat > .gitignore << 'EOF'
# Node
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnp
.pnp.js

# Build
build/
dist/
coverage/

# Environment
.env
.env.*
.env.local
.env.development.local
.env.test.local
.env.production.local

# Terraform — ignore entire folder and all state
terraform/
*.tfstate
*.tfstate.*
*.tfstate.backup
*.tfplan
.terraform/
.terraform.lock.hcl
terraform.tfvars

# AWS
.aws/

# Scripts (infra only)
deploy.sh
destroy.sh
setup.sh
setup-environment.sh

# Logs
*.log
deployment.log

# Docs (infra only)
00_START_HERE.md
DEPLOYMENT_CHECKLIST.md
DEPLOYMENT_GUIDE.md
ENVIRONMENTS.md
INDEX.md
INFRASTRUCTURE_SUMMARY.md
MONITORING_GUIDE.md
PROJECT_STRUCTURE.txt
README_DEPLOYMENT.md
task-def.json

# OS
.DS_Store
Thumbs.db

# IDE
.vscode/
.idea/

# Temp
*.tmp
*.bak
EOF